# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=SportHubDb

# JWT Configuration - IMPORTANTE: Use uma chave forte de pelo menos 32 caracteres em produção
JWT_KEY=your_super_secret_jwt_key_at_least_32_characters_long
JWT_ISSUER=SportHub
JWT_AUDIENCE=SportHubUsers
JWT_EXPIRY_MINUTES=60

# Admin User Configuration
ADMIN_EMAIL=admin@sporthub.com
ADMIN_PASSWORD=your_admin_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Redis Configuration
REDIS_CONNECTION_STRING=redis:6379
REDIS_INSTANCE_NAME=SportHub

# PgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# Environment
ASPNETCORE_ENVIRONMENT=Development
TZ=America/Sao_Paulo
